{% extends 'base.html.twig' %}

{% block title %}Gestion des notes{% endblock %}

{% block body %}
<h2 class="mb-4"><i class="fa-solid fa-clipboard-list"></i> Gestion des notes</h2>

<ul class="nav nav-tabs mb-3">
  <li class="nav-item">
    <a class="nav-link {% if activeTab == 'ajouter' %}active{% endif %}" href="{{ path('prof_notes_ajouter') }}">
      <i class="fa-solid fa-plus"></i> Ajouter une note
    </a>
  </li>
  <li class="nav-item">
    <a class="nav-link {% if activeTab == 'voir' %}active{% endif %}" href="{{ path('prof_notes_voir') }}">
      <i class="fa-solid fa-eye"></i> Voir les notes
    </a>
  </li>
</ul>

{% if activeTab == 'ajouter' and form is defined and form is not null %}
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      {{ form_start(form) }}
      {% for field in form %}
        <div class="mb-3">
          {{ form_label(field) }}
          {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
          {% for error in field.vars.errors %}
            <div class="text-danger">{{ error.message }}</div>
          {% endfor %}
        </div>
      {% endfor %}
      <button type="submit" class="btn btn-success mt-3">
        <i class="fa-solid fa-check"></i> Enregistrer
      </button>
      {{ form_end(form) }}
    </div>
  </div>
{% endif %}

{% if activeTab == 'voir' %}
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Étudiant</th>
        <th>Module</th>
        <th>Note</th>
        <th>Groupe</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for note in notes %}
        <tr>
          <td>{{ note.etudiant.nom }}</td>
          <td>{{ note.module }}</td>
          <td>{{ note.valeur }}</td>
          <td>{{ note.groupe }}</td>
          <td>
            <!-- Bouton Modifier -->
            <a href="{{ path('prof_edit_note', {'id': note.id}) }}" class="btn btn-sm btn-warning">
              <i class="fa-solid fa-pen"></i> Modifier
            </a>
            <!-- Bouton Supprimer -->
            <form method="post" action="{{ path('prof_delete_note', {'id': note.id}) }}" style="display:inline-block" onsubmit="return confirm('Supprimer cette note ?');">
              <input type="hidden" name="_token" value="{{ csrf_token('delete_note_' ~ note.id) }}">
              <button class="btn btn-sm btn-danger">
                <i class="fa-solid fa-trash"></i> Supprimer
              </button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="5" class="text-center text-muted">Aucune note enregistrée</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  {% if labels is defined and values is defined and labels|length > 0 %}
    <h4 class="mt-5"><i class="fa-solid fa-chart-bar"></i> Répartition des notes</h4>
    <canvas id="notesChart" height="100"></canvas>

    <script>
    const ctx = document.getElementById('notesChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: {{ labels|json_encode|raw }},
            datasets: [{
                label: 'Note',
                data: {{ values|json_encode|raw }},
                backgroundColor: 'rgba(54, 162, 235, 0.6)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 1
            }]
        },
        options: {
            scales: {
                y: { beginAtZero: true, max: 20 }
            }
        }
    });
    </script>
  {% endif %}
{% endif %}
{% endblock %}