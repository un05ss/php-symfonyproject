<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Connexion - GESTIOplus</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&display=swap');

    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', sans-serif;
      background-color: #0d6efd;
      color: white;
    }

    .login-container {
      display: flex;
      min-height: 100vh;
    }

    .left-panel {
      flex: 1;
      padding: 60px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background-color: #0a58ca;
    }

    .left-panel h1 {
      font-family: 'Montserrat', sans-serif;
      font-size: 36px;
      margin-bottom: 20px;
    }

    .left-panel p {
      font-size: 18px;
      line-height: 1.6;
    }

    .right-panel {
      flex: 1;
      background-color: white;
      color: #333;
      padding: 60px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .logo {
      font-size: 28px;
      font-weight: bold;
      font-family: 'Montserrat', sans-serif;
      color: #0d6efd;
      margin-bottom: 30px;
      text-align: center;
    }

    .logo i {
      margin-right: 10px;
    }

    .form-control {
      height: 45px;
      margin-bottom: 20px;
      border-radius: 8px;
    }

    .btn-login {
      width: 100%;
      height: 45px;
      border-radius: 8px;
      background-color: #0d6efd;
      color: white;
      font-weight: bold;
      border: none;
    }

    .btn-login:hover {
      background-color: #0a58ca;
    }

    .forgot-link {
      display: block;
      text-align: right;
      margin-top: 10px;
      font-size: 14px;
      color: #0d6efd;
      text-decoration: none;
    }

    .forgot-link:hover {
      text-decoration: underline;
    }

    .footer {
      text-align: center;
      font-size: 12px;
      color: #666;
      margin-top: 40px;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <!-- Partie gauche : message de bienvenue -->
    <div class="left-panel">
      <h1>Bienvenue dans votre espace privé</h1>
      <p>
        Un système d'information intégré qui permet la mise en place de nouvelles méthodes de gestion scolaire.
        GESTIOplus vous accompagne dans la gestion moderne des séances, groupes et modules.
      </p>
    </div>

    <!-- Partie droite : formulaire -->
    <div class="right-panel">
      <div class="logo">
        <i class="fa-solid fa-graduation-cap"></i> GESTIO<span style="color:#333">plus</span><br>
        <small style="font-size: 14px; font-weight: normal;">Système de gestion scolaire</small>
      </div>

      {% if error %}
        <div class="alert alert-danger">Identifiants incorrects ❌</div>
      {% endif %}

      <form method="post">
        <input type="text" name="username" id="username" class="form-control" placeholder="Email" required>
        <input type="password" name="password" id="password" class="form-control" placeholder="Mot de passe" required>
        <button type="submit" class="btn btn-login">Se connecter</button>
        <a href="#" class="forgot-link">Mot de passe oublié ?</a>
      </form>

      <!-- Footer -->
      <div class="footer">
        Developped by Youness Talib - github.com/un05ss
      </div>
    </div>
  </div>
</body>
</html>