<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}GESTIOplus{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <!-- Styles personnalisés -->
    {% block stylesheets %}
      <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    {% endblock %}

    <style>
        body {
            background: linear-gradient(135deg, #f4f6f9, #e3f2fd);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        nav.navbar {
            margin-bottom: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .stat-box {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .stat-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        .stat-box h3 {
            font-size: 28px;
            color: #0d6efd;
        }
        .stat-box p {
            font-size: 16px;
            color: #555;
        }
        .btn-lg {
            font-size: 20px;
            border-radius: 12px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .btn-lg:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }
        footer {
            margin-top: auto;
            background: #0d6efd;
            color: white;
            text-align: center;
            padding: 10px;
        }
    </style>
</head>
<body>

<!-- Barre de navigation -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container-fluid">
    <a class="navbar-brand" href="{{ path('prof_accueil') }}">
      <i class="fa-solid fa-graduation-cap"></i> GESTIOplus
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="{{ path('prof_accueil') }}"><i class="fa-solid fa-house"></i> Accueil</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ path('prof_seances') }}"><i class="fa-solid fa-calendar-check"></i> Séances</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ path('prof_groupes') }}"><i class="fa-solid fa-users"></i> Groupes</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ path('prof_modules') }}"><i class="fa-solid fa-book"></i> Modules</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ path('prof_notes_ajouter') }}"><i class="fa-solid fa-clipboard-list"></i> Notes</a></li>
        <li class="nav-item"><a class="nav-link" href="{{ path('prof_logout') }}"><i class="fa-solid fa-right-from-bracket"></i> Déconnexion</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Contenu principal -->
<div class="container">
    {% block body %}{% endblock %}
</div>

<!-- Footer -->
<footer>
  <p>GESTIOplus © 2026 - Tous droits réservés</p>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Chart.js pour les graphiques -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{% block javascripts %}
  <script src="{{ asset('js/script.js') }}"></script>
{% endblock %}
</body>
</html>