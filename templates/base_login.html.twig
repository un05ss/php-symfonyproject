<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}Connexion Professeur{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(to right, #007bff, #6610f2);
        color: white;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .login-container {
        background: white;
        color: black;
        border-radius: 12px;
        box-shadow: 0 0 25px rgba(0,0,0,0.3);
        display: flex;
        flex-wrap: wrap;
        max-width: 900px;
        width: 100%;
        overflow: hidden;
      }
      .login-left, .login-right {
        flex: 1 1 50%;
        padding: 40px;
      }
      .login-left {
        background: #f8f9fa;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .login-left h2 {
        color: #6610f2;
        font-weight: bold;
        margin-bottom: 20px;
      }
      .login-left p {
        font-size: 16px;
        color: #333;
      }
      .logo {
        font-size: 28px;
        font-weight: bold;
        color: #6610f2;
        margin-bottom: 20px;
      }
      .logo i {
        color: #007bff;
        margin-right: 8px;
      }
      .form-label {
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    {% block body %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>